  "keyFeatures": [
    "Full load lifecycle management (Upcoming → Dispatched → InTransit → Delivered)",
    "Real-time ELD position tracking from Zippy, Samsara, UTrackin, and LevelELD",
    "Multi-tenant data isolation via EF Core global query filters",
    "Hybrid routing engine: OSRM primary with Google Maps / Valhalla / HERE fallback",
    "Automated Telegram notifications for drivers and dispatchers",
    "AI-powered ratecon extraction and ticket suggestion via AskAI",
    "Hangfire background jobs for TMS/ELD imports and monitoring",
    "Role-based permission system with 100+ granular permissions",
    "QuickManage TMS integration with HMAC-verified webhooks",
    "Nylas email processing for automated ratecon ingestion"
  ],
